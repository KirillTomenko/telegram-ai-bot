# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# === AI API Ключи (укажите хотя бы один) ===

# ProxyAPI (приоритет, если только он указан)
PROXYAPI_KEY=your_proxyapi_key_here
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

# OpenAI (опционально)
OPENAI_API_KEY=sk-your-openai-key-here

# GenAPI (опционально)
GENAPI_KEY=your_genapi_key_here
GENAPI_BASE_URL=https://api.genapi.ai/v1

# === Настройки модели ===
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=1000
MAX_CONTEXT_MESSAGES=10  # Сколько последних сообщений хранить в контексте